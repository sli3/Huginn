{
  "$schema": "https://opencode.ai/mcp.json",
  "mcpServers": {
    "local-files": {
      "type": "local",
      "command": [
        "npx", "-y",
        "@modelcontextprotocol/server-filesystem",
        "[ABSOLUTE-PATH-TO-PROJECT]"
      ],
      "enabled": true
    },
    "example-remote": {
      "type": "url",
      "url": "https://[MCP-SERVER-HOST]/sse",
      "enabled": false,
      "comment": "Remove this block if you do not need a remote MCP server"
    }
  }
}
